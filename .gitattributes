# Normalize line endings: text files commit as LF (matches Prettier endOfLine).
* text=auto eol=lf

# Binary assets — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.avif  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.pdf   binary

